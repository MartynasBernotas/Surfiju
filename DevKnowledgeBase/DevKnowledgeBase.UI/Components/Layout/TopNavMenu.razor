@using DevKnowledgeBase.UI.Services
@using Microsoft.AspNetCore.Components.Authorization

@inject NavigationManager Navigation
@inject IAuthenticationService AuthService

<div style="display:flex; align-items:center; gap:4px;">
    <MudButton Href="/"
               Variant="Variant.Text"
               Color="Color.Inherit"
               Class="@GetActiveClass("/")"
               Style="border-radius:20px; min-width:0;">
        Home
    </MudButton>
    <MudButton Href="/camps"
               Variant="Variant.Text"
               Color="Color.Inherit"
               Class="@GetActiveClass("/camps")"
               Style="border-radius:20px; min-width:0;">
        Surf Camps
    </MudButton>
</div>

@code {
    private string GetActiveClass(string href)
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);

        if (href == "/" && string.IsNullOrEmpty(relativePath))
            return "nav-active";

        if (href != "/" && relativePath.StartsWith(href.TrimStart('/')))
            return "nav-active";

        return string.Empty;
    }
}
