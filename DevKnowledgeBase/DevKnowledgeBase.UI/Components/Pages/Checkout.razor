@page "/checkout/{BookingId:guid}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject IBookingService BookingService
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Checkout — Surfiju</PageTitle>

<div style="background: linear-gradient(135deg, #03045E 0%, #0077B6 100%); padding:48px 24px 60px; color:white; position:relative; overflow:hidden;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Large" Style="color:rgba(255,255,255,0.9);" />
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:800;">Checkout</MudText>
                <MudText Typo="Typo.body2" Style="opacity:0.8;">Complete your payment to confirm your booking</MudText>
            </div>
        </MudStack>
    </MudContainer>
    <div style="position:absolute; bottom:-2px; left:0; width:100%; overflow:hidden; line-height:0;">
        <svg viewBox="0 0 1440 50" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block; width:100%; height:50px;">
            <path d="M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z" fill="var(--mud-palette-background)" />
        </svg>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-6 mb-10">
    @if (booking == null)
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-10">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </MudStack>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="3" Style="border-radius:20px;">
            <MudText Typo="Typo.h6" Style="font-weight:700; margin-bottom:16px;">Order Summary</MudText>
            <MudStack Spacing="2" Class="mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText>Camp</MudText>
                    <MudText Style="font-weight:600;">@booking.CampName</MudText>
                </MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText>Participants</MudText>
                    <MudText Style="font-weight:600;">@booking.Participants</MudText>
                </MudStack>
                <MudDivider />
                <MudStack Row="true" Justify="Justify.SpaceBetween">
                    <MudText Style="font-weight:700; font-size:1.1rem;">Total</MudText>
                    <MudText Style="font-weight:800; font-size:1.1rem; color:#0077B6;">€@booking.TotalPrice.ToString("F2")</MudText>
                </MudStack>
            </MudStack>

            <MudDivider Class="mb-4" />

            <MudText Typo="Typo.subtitle2" Style="margin-bottom:8px;">Card Details</MudText>
            <div id="card-element" style="padding:12px; border:1px solid var(--mud-palette-lines-default); border-radius:8px; margin-bottom:16px;"></div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="PayNow"
                       Disabled="@processing"
                       Style="border-radius:24px; font-weight:700;">
                @if (processing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Processing...</span>
                }
                else
                {
                    <span>Pay Now</span>
                }
            </MudButton>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter] public Guid BookingId { get; set; }
    [SupplyParameterFromQuery] public string? ClientSecret { get; set; }

    private BookingModel? booking;
    private string? errorMessage;
    private bool processing;
    private bool stripeInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(ClientSecret))
        {
            Navigation.NavigateTo("/my-bookings");
            return;
        }

        var bookings = await BookingService.GetUserBookingsAsync();
        booking = bookings.FirstOrDefault(b => b.Id == BookingId);
        if (booking == null)
        {
            Navigation.NavigateTo("/my-bookings");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && booking != null && !stripeInitialized)
        {
            stripeInitialized = true;
            var publishableKey = Configuration["Stripe:PublishableKey"] ?? string.Empty;
            await JS.InvokeVoidAsync("stripeInterop.init", publishableKey);
        }
    }

    private async Task PayNow()
    {
        if (string.IsNullOrEmpty(ClientSecret))
        {
            errorMessage = "Payment session expired. Please try booking again.";
            return;
        }

        processing = true;
        errorMessage = null;

        try
        {
            var payResult = await JS.InvokeAsync<StripePaymentResult>("stripeInterop.confirmPayment", ClientSecret);
            if (payResult.Success)
            {
                Snackbar.Add("Payment successful! Your booking is confirmed.", Severity.Success);
                Navigation.NavigateTo("/my-bookings?success=true");
            }
            else
            {
                errorMessage = payResult.Error ?? "Payment failed. Please try again.";
            }
        }
        finally
        {
            processing = false;
        }
    }

    private class StripePaymentResult
    {
        public bool Success { get; set; }
        public string? Error { get; set; }
    }
}
