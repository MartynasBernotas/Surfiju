@page "/about"

<PageTitle>About Surfiju</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-5">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h4" Class="mb-4">About Surfiju</MudText>

        <MudText Typo="Typo.body1" Class="mb-4">
            Surfiju is a platform that connects surf camp organizers with participants.
            Whether you're looking to discover your next surf adventure or manage your own camp,
            Surfiju makes it easy.
        </MudText>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.h5" Class="mb-3">For Participants</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            Browse surf camps from around the world, view details, check availability, and book your spot
            in just a few clicks.
        </MudText>

        <MudText Typo="Typo.h5" Class="mb-3">For Organizers</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            Create and manage your surf camps, upload photos, set pricing, and track bookings —
            all from one simple dashboard.
        </MudText>

        <MudDivider Class="my-4" />

        <MudButton Href="/camps" Variant="Variant.Filled" Color="Color.Primary">
            Browse Surf Camps
        </MudButton>
    </MudPaper>
</MudContainer>
