@page "/organizer/bookings"
@using DevKnowledgeBase.UI.Models
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json

@attribute [Authorize(Roles = "Admin, Organizer")]

@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICampService CampService

<PageTitle>Organizer Dashboard — Surfiju</PageTitle>

<!-- Page Header -->
<div style="background: linear-gradient(135deg, #03045E 0%, #0077B6 100%); padding:48px 24px 60px; color:white; position:relative; overflow:hidden;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Large" Style="color:rgba(255,255,255,0.9);" />
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:800;">Organizer Dashboard</MudText>
                <MudText Typo="Typo.body2" Style="opacity:0.8;">Manage bookings across your surf camps</MudText>
            </div>
        </MudStack>
    </MudContainer>
    <div style="position:absolute; bottom:-2px; left:0; width:100%; overflow:hidden; line-height:0;">
        <svg viewBox="0 0 1440 50" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="display:block; width:100%; height:50px;">
            <path d="M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z" fill="var(--mud-palette-background)" />
        </svg>
    </div>
</div>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-10">

    @if (summary != null)
    {
        <MudGrid Class="mb-5">
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4" Elevation="3" Style="background:linear-gradient(135deg,#0077B6,#00B4D8); color:white; border-radius:12px;">
                    <MudText Typo="Typo.h5" Style="font-weight:800; color:white;">€@summary.TotalRevenue.ToString("F0")</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.06em;">Total Revenue</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4" Elevation="3" Style="background:linear-gradient(135deg,#52B788,#40916C); color:white; border-radius:12px;">
                    <MudText Typo="Typo.h5" Style="font-weight:800; color:white;">@summary.TotalBookings</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.06em;">Total Bookings</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4" Elevation="3" Style="background:linear-gradient(135deg,#F4A261,#E76F51); color:white; border-radius:12px;">
                    <MudText Typo="Typo.h5" Style="font-weight:800; color:white;">@summary.ConfirmedBookings</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.06em;">Confirmed</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Class="pa-4" Elevation="3" Style="background:linear-gradient(135deg,#023E8A,#03045E); color:white; border-radius:12px;">
                    <MudText Typo="Typo.h5" Style="font-weight:800; color:white;">@summary.PendingBookings</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:0.06em;">Pending</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <!-- Filters -->
    <MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-radius:12px;">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="5">
                <MudSelect T="Guid?" Label="Filter by Camp" Value="@selectedCampId" ValueChanged="OnCampFilterChanged" Clearable="true" Dense="true">
                    @foreach (var camp in camps)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)camp.Id)">@camp.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="7">
                <MudChipSet T="BookingStatus?" SelectedValue="@selectedStatus" SelectedValueChanged="OnStatusFilterChanged" SelectionMode="SelectionMode.SingleSelection">
                    <MudChip T="BookingStatus?" Value="@((BookingStatus?)null)" Color="Color.Default" Variant="Variant.Outlined">All</MudChip>
                    <MudChip T="BookingStatus?" Value="@((BookingStatus?)BookingStatus.Pending)" Color="Color.Warning" Variant="Variant.Outlined">Pending</MudChip>
                    <MudChip T="BookingStatus?" Value="@((BookingStatus?)BookingStatus.Confirmed)" Color="Color.Success" Variant="Variant.Outlined">Confirmed</MudChip>
                    <MudChip T="BookingStatus?" Value="@((BookingStatus?)BookingStatus.Cancelled)" Color="Color.Error" Variant="Variant.Outlined">Cancelled</MudChip>
                    <MudChip T="BookingStatus?" Value="@((BookingStatus?)BookingStatus.Completed)" Color="Color.Info" Variant="Variant.Outlined">Completed</MudChip>
                </MudChipSet>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (bookings == null)
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-10">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </MudStack>
    }
    else if (!bookings.Any())
    {
        <MudPaper Class="pa-10" Elevation="2" Style="border-radius:20px; text-align:center;">
            <MudIcon Icon="@Icons.Material.Filled.BookOnline"
                     Style="font-size:5rem; color:var(--mud-palette-text-secondary); opacity:0.4; margin-bottom:16px;" />
            <MudText Typo="Typo.h6" Style="font-weight:700; margin-bottom:8px;">No bookings found</MudText>
            <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">
                No bookings match the current filters.
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="3" Style="border-radius:16px; overflow:hidden;">
            <MudTable Items="@bookings" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh Style="font-weight:700;">Camp</MudTh>
                    <MudTh Style="font-weight:700;">Surfer Name</MudTh>
                    <MudTh Style="font-weight:700;">Email</MudTh>
                    <MudTh Style="font-weight:700;">Participants</MudTh>
                    <MudTh Style="font-weight:700;">Total</MudTh>
                    <MudTh Style="font-weight:700;">Status</MudTh>
                    <MudTh Style="font-weight:700;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Camp">
                        <MudText Style="font-weight:600;">@context.CampName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Surfer Name">@context.UserName</MudTd>
                    <MudTd DataLabel="Email">
                        <MudText Typo="Typo.body2">@context.UserEmail</MudText>
                    </MudTd>
                    <MudTd DataLabel="Participants">@context.Participants</MudTd>
                    <MudTd DataLabel="Total">
                        <MudText Style="font-weight:700; color:#0077B6;">€@context.TotalPrice.ToString("F2")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Color="@GetStatusColor(context.Status)"
                                 Size="Size.Small"
                                 Variant="Variant.Filled">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            @if (context.Status == BookingStatus.Pending)
                            {
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Color="Color.Success"
                                           OnClick="() => ConfirmBooking(context)"
                                           Style="border-radius:16px;">
                                    Confirm
                                </MudButton>
                            }
                            @if (context.Status != BookingStatus.Cancelled && context.Status != BookingStatus.Refunded && context.Status != BookingStatus.Completed)
                            {
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           OnClick="() => OpenCancelDialog(context)"
                                           Style="border-radius:16px;">
                                    Cancel
                                </MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<OrganizerBookingModel>? bookings;
    private BookingSummaryModel? summary;
    private List<CampModel> camps = new();
    private Guid? selectedCampId;
    private BookingStatus? selectedStatus;

    private HttpClient Http => HttpClientFactory.CreateClient("API");

    protected override async Task OnInitializedAsync()
    {
        camps = await CampService.GetOrganizerCampsAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        await Task.WhenAll(LoadBookings(), LoadSummary());
    }

    private async Task LoadBookings()
    {
        var url = BuildUrl("api/organizer/bookings");
        bookings = await Http.GetFromJsonAsync<List<OrganizerBookingModel>>(url) ?? new();
    }

    private async Task LoadSummary()
    {
        var url = BuildUrl("api/organizer/bookings/summary");
        summary = await Http.GetFromJsonAsync<BookingSummaryModel>(url);
    }

    private string BuildUrl(string baseUrl)
    {
        var queryParams = new List<string>();
        if (selectedCampId.HasValue) queryParams.Add($"campId={selectedCampId.Value}");
        if (selectedStatus.HasValue) queryParams.Add($"status={(int)selectedStatus.Value}");
        return queryParams.Count > 0 ? $"{baseUrl}?{string.Join("&", queryParams)}" : baseUrl;
    }

    private async Task OnCampFilterChanged(Guid? value)
    {
        selectedCampId = value;
        await LoadData();
    }

    private async Task OnStatusFilterChanged(BookingStatus? value)
    {
        selectedStatus = value;
        await LoadData();
    }

    private async Task ConfirmBooking(OrganizerBookingModel booking)
    {
        var response = await Http.PostAsJsonAsync($"api/bookings/{booking.BookingId}/confirm", new { paymentIntentId = booking.PaymentIntentId ?? string.Empty });
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add($"Booking for {booking.UserName} confirmed.", Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add("Failed to confirm booking.", Severity.Error);
        }
    }

    private async Task OpenCancelDialog(OrganizerBookingModel booking)
    {
        var parameters = new DialogParameters
        {
            ["ContentText"] = $"Cancel booking for \"{booking.UserName}\" at {booking.CampName}? This cannot be undone.",
            ["ButtonText"] = "Yes, Cancel",
            ["Color"] = Color.Error
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Cancel Booking", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var response = await Http.DeleteAsync($"api/bookings/{booking.BookingId}?reason=Cancelled+by+organizer");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Booking cancelled.", Severity.Success);
                await LoadData();
            }
            else
            {
                Snackbar.Add("Failed to cancel booking.", Severity.Error);
            }
        }
    }

    private Color GetStatusColor(BookingStatus status) => status switch
    {
        BookingStatus.Pending => Color.Warning,
        BookingStatus.Confirmed => Color.Success,
        BookingStatus.Cancelled => Color.Error,
        BookingStatus.Completed => Color.Info,
        BookingStatus.Refunded => Color.Secondary,
        _ => Color.Default
    };

    private class OrganizerBookingModel
    {
        public Guid BookingId { get; set; }
        public string CampName { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string UserEmail { get; set; } = string.Empty;
        public int Participants { get; set; }
        public decimal TotalPrice { get; set; }
        public BookingStatus Status { get; set; }
        public DateTime BookingDate { get; set; }
        public string? PaymentIntentId { get; set; }
    }

    private class BookingSummaryModel
    {
        public decimal TotalRevenue { get; set; }
        public int TotalBookings { get; set; }
        public int ConfirmedBookings { get; set; }
        public int PendingBookings { get; set; }
        public int CancelledBookings { get; set; }
    }
}
