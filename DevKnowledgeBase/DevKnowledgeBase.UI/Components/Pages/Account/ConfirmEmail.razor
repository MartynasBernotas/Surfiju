@page "/confirm-email"
@using DevKnowledgeBase.UI.Common

@inject NavigationManager Navigation
@inject IAuthenticationService AuthService

<PageTitle>Email Confirmation — Surfiju</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-card">
        <MudPaper Elevation="6" Style="border-radius:20px; overflow:hidden; width:100%;">
            <div class="auth-card-top">
                <div class="auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Style="color:white; font-size:1.75rem;" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight:800; color:white; margin-bottom:4px;">Email Confirmation</MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.75);">
                    Verifying your email address
                </MudText>
            </div>

            <div class="auth-card-body">
                @if (Message == null)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="3">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">
                            Confirming your email...
                        </MudText>
                    </MudStack>
                }
                else
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@(succeeded ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Error)"
                                 Style="@($"font-size:3.5rem; color:{(succeeded ? "#52B788" : "#EF476F")};")" />

                        <MudAlert Severity="@(succeeded ? Severity.Success : Severity.Error)" Dense="true">
                            @Message
                        </MudAlert>

                        <MudButton Href="/login"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Style="border-radius:24px;">
                            @(succeeded ? "Sign In Now" : "Back to Login")
                        </MudButton>
                    </MudStack>
                }
            </div>
        </MudPaper>
    </div>
</div>

@code {
    private string UserId = string.Empty;
    private string Token = string.Empty;
    private string Message = null;
    private bool succeeded = false;

    protected override async Task OnInitializedAsync()
    {
        Navigation.TryGetQueryString<string>("userId", out UserId);
        Navigation.TryGetQueryString<string>("token", out Token);
        var result = await AuthService.ConfirmEmail(UserId, Token);
        Message = result;
        succeeded = !string.IsNullOrEmpty(result) && !result.ToLower().Contains("error") && !result.ToLower().Contains("fail") && !result.ToLower().Contains("invalid");
    }
}
