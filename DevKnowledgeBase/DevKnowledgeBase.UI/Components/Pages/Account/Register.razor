@page "/register"
@using DevKnowledgeBase.UI.Services
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation
@inject LoadingService LoadingService

<PageTitle>Register — Surfiju</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-card">
        <MudPaper Elevation="6" Style="border-radius:20px; overflow:hidden; width:100%;">

            <!-- Top accent -->
            <div class="auth-card-top">
                <div class="auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Waves" Style="color:white; font-size:1.75rem;" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight:800; color:white; margin-bottom:4px;">Join Surfiju</MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.75);">
                    Create your free account today
                </MudText>
            </div>

            <!-- Form body -->
            <div class="auth-card-body">
                @if (registrationSuccess)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead"
                                 Style="font-size:4rem; color:#52B788;" />
                        <MudText Typo="Typo.h6" Style="font-weight:700; text-align:center;">
                            Check your inbox!
                        </MudText>
                        <MudAlert Severity="Severity.Success" Dense="true">
                            We've sent a confirmation link to your email. Please confirm your account before signing in.
                        </MudAlert>
                        <MudButton Href="/login"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Style="border-radius:24px;">
                            Go to Login
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    @if (ErrorMessages?.Any() == true)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">
                            <ul style="margin:0; padding-left:1rem;">
                                @foreach (var error in ErrorMessages)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </MudAlert>
                    }

                    <MudForm Model="@Model"
                             @ref="form"
                             Validation="@(modelValidator.ValidateValue)"
                             ValidationDelay="0">
                        <MudTextField @bind-Value="Model.Username"
                                      Label="Username"
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      For="@(() => Model.Username)"
                                      Class="mb-3"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Person" />

                        <MudTextField @bind-Value="Model.Email"
                                      Label="Email address"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Email"
                                      Immediate="true"
                                      For="@(() => Model.Email)"
                                      Class="mb-3"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email" />

                        <MudTextField @bind-Value="Model.Password"
                                      Label="Password"
                                      Variant="Variant.Outlined"
                                      InputType="PasswordInputType"
                                      Immediate="true"
                                      For="@(() => Model.Password)"
                                      Class="mb-3"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@Icons.Material.Filled.Visibility"
                                      OnAdornmentClick="TogglePasswordVisibility" />

                        <MudTextField @bind-Value="Model.ConfirmPassword"
                                      Label="Confirm password"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Password"
                                      Immediate="true"
                                      For="@(() => Model.ConfirmPassword)"
                                      Class="mb-4" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   OnClick="@(async () => await RegisterUser())"
                                   Style="border-radius:24px; font-size:1rem; padding:12px;">
                            Create Account
                        </MudButton>
                    </MudForm>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">
                        Already have an account?
                        <MudLink Href="/login" Color="Color.Primary" Style="font-weight:600;">
                            Sign in
                        </MudLink>
                    </MudText>
                }
            </div>
        </MudPaper>
    </div>
</div>

@code {
    private MudForm form;
    private RegisterModel Model = new();
    private RegisterModelValidator modelValidator = new();
    private List<string> ErrorMessages = new();
    private bool registrationSuccess = false;
    private InputType PasswordInputType = InputType.Password;

    protected override async Task OnInitializedAsync()
    {
        LoadingService.Show();
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (isAuthenticated)
        {
            Navigation.NavigateTo("/");
        }
        LoadingService.Hide();
    }

    private async Task RegisterUser()
    {
        ErrorMessages.Clear();
        LoadingService.Show();
        await form.Validate();

        if (!form.IsValid)
        {
            LoadingService.Hide();
            return;
        }

        var result = await AuthService.RegisterAsync(Model.Username, Model.Email, Model.Password);
        if (!result.Success)
        {
            ErrorMessages.Add(result.ErrorMessage);
        }
        else
        {
            registrationSuccess = true;
        }

        LoadingService.Hide();
    }

    private void TogglePasswordVisibility()
    {
        PasswordInputType = PasswordInputType == InputType.Password ? InputType.Text : InputType.Password;
    }
}
