@page "/forgot-password"
@inject IAuthenticationService AuthService

<PageTitle>Forgot Password — Surfiju</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-card">
        <MudPaper Elevation="6" Style="border-radius:20px; overflow:hidden; width:100%;">

            <div class="auth-card-top">
                <div class="auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="color:white; font-size:1.75rem;" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight:800; color:white; margin-bottom:4px;">Reset Password</MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.75);">
                    Enter your email to receive a reset link
                </MudText>
            </div>

            <div class="auth-card-body">
                @if (!string.IsNullOrEmpty(Message))
                {
                    <MudAlert Severity="@(succeeded ? Severity.Success : Severity.Error)"
                              Class="mb-4"
                              Dense="true">
                        @Message
                    </MudAlert>

                    @if (succeeded)
                    {
                        <MudButton Href="/login"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Style="border-radius:24px;">
                            Back to Login
                        </MudButton>
                    }
                }

                @if (!succeeded)
                {
                    <MudForm @ref="form">
                        <MudTextField @bind-Value="Email"
                                      Label="Email address"
                                      InputType="InputType.Email"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      Class="mb-4"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email" />

                        <MudButton OnClick="@(async () => await SendResetLink())"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   Style="border-radius:24px; font-size:1rem; padding:12px;">
                            Send Reset Link
                        </MudButton>
                    </MudForm>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.body2" Align="Align.Center" Style="color:var(--mud-palette-text-secondary);">
                        Remember your password?
                        <MudLink Href="/login" Color="Color.Primary" Style="font-weight:600;">Sign in</MudLink>
                    </MudText>
                }
            </div>
        </MudPaper>
    </div>
</div>

@code {
    private string Email = string.Empty;
    private string Message = string.Empty;
    private bool succeeded = false;
    private MudForm form = new();

    private async Task SendResetLink()
    {
        var authResult = await AuthService.ForgotPasswordAsync(Email);
        succeeded = authResult.Success;
        Message = authResult.Success ? "Check your email for the reset link!" : authResult.ErrorMessage;
    }
}
